{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    { "source": "/lenterailmu/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/lenterailmu/components/(.*)", "destination": "/components/$1" },
    { "source": "/lenterailmu/firebase/(.*)", "destination": "/firebase/$1" },
    { "source": "/lenterailmu/pages/(.*)", "destination": "/api/pages/$1" },
    { "source": "/lenterailmu/?$", "destination": "/api/index.php" },
    
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/components/(.*)", "destination": "/components/$1" },
    { "source": "/firebase/(.*)", "destination": "/firebase/$1" },
    { "source": "/pages/(.*)", "destination": "/api/pages/$1" },
    { "source": "/$", "destination": "/api/index.php" }
  ]
}
