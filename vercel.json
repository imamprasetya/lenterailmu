{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    { "source": "/lenterailmu/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/lenterailmu/components/:path*", "destination": "/components/:path*" },
    { "source": "/lenterailmu/firebase/:path*", "destination": "/firebase/:path*" },
    { "source": "/lenterailmu/pages/:path*", "destination": "/api/pages/:path*" },
    { "source": "/lenterailmu", "destination": "/api/index.php" },
    { "source": "/lenterailmu/", "destination": "/api/index.php" },
    
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/components/:path*", "destination": "/components/:path*" },
    { "source": "/firebase/:path*", "destination": "/firebase/:path*" },
    { "source": "/pages/:path*", "destination": "/api/pages/:path*" },
    { "source": "/", "destination": "/api/index.php" }
  ]
}
